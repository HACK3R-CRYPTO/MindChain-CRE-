# ==========================================
# Root Environment Configuration (Simulation)
# ==========================================
# These variables are required by the CRE CLI when running `npm run dev:workflow`

# AI Service Keys
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_VAR=your_gemini_api_key_here

# Wallet Configuration (For testing interactions)
SEPOLIA_PRIVATE_KEY=your_wallet_private_key_here

# Blockchain RPC Endpoints
SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Note: The frontend has its own .env.local file located in `frontend/.env.local`
# Note: The smart contracts have their own .env file located in `contracts/.env`
